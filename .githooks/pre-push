#!/usr/bin/env bash
# gaze-laravel pre-push gate.
#
# Replaces the killed .github/workflows/test.yml. Catches Pest + PHPStan
# regressions locally before push, without burning GitHub Actions minutes.
#
# Activate per clone (one-time):
#   git config core.hooksPath .githooks
#
# Emergency bypass (WIP backups only):
#   SKIP_HOOK=1 git push ...

set -euo pipefail

if [[ "${SKIP_HOOK:-0}" == "1" ]]; then
  echo "⚠  SKIP_HOOK=1 set — pre-push gate bypassed."
  echo "   You are pushing without running tests/analyse locally."
  echo "   Only do this for WIP-branch backups; never for shared branches or tags."
  exit 0
fi

# --- docs-only fast-path -----------------------------------------------------
# Skip composer test/analyse when every changed file in this push matches a
# documentation/text allowlist. Saves several minutes on doc-only pushes
# (README tweaks, .claude/ skill updates, CHANGELOG additions, etc.).
# Override with FORCE_FULL_GATE=1 git push to run the full gate anyway.

zero="0000000000000000000000000000000000000000"
push_has_refs=0
changed_files=""

while read -r local_ref local_sha remote_ref remote_sha; do
    push_has_refs=1
    [[ "$local_sha" == "$zero" ]] && continue
    if [[ "$remote_sha" == "$zero" ]]; then
        base=$(git merge-base "$local_sha" origin/main 2>/dev/null || true)
        if [[ -n "$base" ]]; then
            range_files=$(git diff --name-only "$base" "$local_sha")
        else
            range_files=$(git diff-tree --no-commit-id --name-only -r "$local_sha")
        fi
    else
        range_files=$(git diff --name-only "$remote_sha" "$local_sha")
    fi
    [[ -n "$range_files" ]] && changed_files+="${range_files}"$'\n'
done

if [[ "$push_has_refs" == "1" && "${FORCE_FULL_GATE:-0}" != "1" && -n "$changed_files" ]]; then
    is_docs_only=1
    non_doc_sample=""
    while IFS= read -r f; do
        [[ -z "$f" ]] && continue
        case "$f" in
            *.md|*.txt|*.rst|*.adoc) ;;
            *.png|*.jpg|*.jpeg|*.gif|*.svg|*.webp|*.ico) ;;
            LICENSE|LICENSE-*|COPYING|NOTICE|AUTHORS|CODEOWNERS) ;;
            docs/*|.claude/*|.ai/*) ;;
            AGENTS.md|CLAUDE.md|CHANGELOG.md|README.md|ROADMAP.md|CONTRIBUTING.md|SECURITY.md|GOVERNANCE.md) ;;
            .github/ISSUE_TEMPLATE/*|.github/PULL_REQUEST_TEMPLATE.md|.github/FUNDING.yml) ;;
            *)
                is_docs_only=0
                non_doc_sample="$f"
                break
                ;;
        esac
    done <<< "$changed_files"

    if [[ "$is_docs_only" == "1" ]]; then
        echo "==> pre-push: docs-only push detected — skipping composer test/analyse" >&2
        echo "    Override with FORCE_FULL_GATE=1 git push to run gates anyway." >&2
        exit 0
    else
        echo "==> pre-push: code change detected ($non_doc_sample) — running full gate" >&2
    fi
fi
# --- end docs-only fast-path -------------------------------------------------

export GAZE_SKIP_BINARY_DOWNLOAD=1

echo "▶  pre-push gate: composer test (Pest)"
composer test || { echo; echo "✗  Pest failed. Fix and push again. Bypass with SKIP_HOOK=1."; exit 1; }

echo "▶  pre-push gate: composer analyse (PHPStan)"
composer analyse || { echo; echo "✗  PHPStan failed. Fix and push again."; exit 1; }

echo "✓  pre-push gate clean. Pushing."
