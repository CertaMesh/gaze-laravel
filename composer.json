{
    "name": "empiretwo/gaze-laravel",
    "description": "Redact PII, PHI & secrets before they reach OpenAI/Anthropic/Gemini — one Gaze::clean()/Gaze::restore() call. Reversible, signed-encrypted pseudonymization for Laravel LLM & agent pipelines (GDPR/EU AI Act).",
    "license": "Apache-2.0",
    "keywords": ["laravel", "gdpr", "pii", "anonymization", "pseudonymization", "privacy", "redaction", "llm", "ai", "phi", "secrets", "openai", "anthropic", "gemini", "dlp", "compliance", "eu-ai-act", "agents"],
    "homepage": "https://github.com/CertaMesh/gaze-laravel",
    "support": {
        "issues": "https://github.com/CertaMesh/gaze-laravel/issues",
        "source": "https://github.com/CertaMesh/gaze-laravel",
        "docs": "https://github.com/CertaMesh/gaze-laravel/blob/main/docs"
    },
    "authors": [
        {
            "name": "Naoray",
            "homepage": "https://github.com/Naoray"
        },
        {
            "name": "Lord Eagle",
            "email": "hello@lordeagle.ie",
            "homepage": "https://github.com/lord-eagle"
        },
        {
            "name": "The Gaze Contributors",
            "homepage": "https://github.com/CertaMesh/gaze-laravel/graphs/contributors"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-phar": "*",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/encryption": "^11.0|^12.0|^13.0",
        "illuminate/process": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "composer-plugin-api": "^2.0",
        "symfony/process": "^7.0 || ^8.0",
        "yosymfony/toml": "^1.0",
        "symfony/http-client": "^7.0 || ^8.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpstan/phpstan": "^1.11",
        "laravel/pint": "^1.17",
        "composer/composer": "^2.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Naoray\\GazeLaravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Naoray\\GazeLaravel\\Tests\\": "tests/"
        },
        "files": [
            "tests/Helpers.php"
        ]
    },
    "extra": {
        "class": "Naoray\\GazeLaravel\\Install\\GazeInstallerPlugin",
        "branch-alias": {
            "dev-main": "0.x-dev"
        },
        "laravel": {
            "providers": ["Naoray\\GazeLaravel\\GazeServiceProvider"],
            "aliases": {"Gaze": "Naoray\\GazeLaravel\\Facades\\Gaze"}
        }
    },
    "type": "composer-plugin",
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse --memory-limit=512M",
        "format": "pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "empiretwo/gaze-laravel": true
        }
    }
}
