{
    "name": "naoray/gaze-laravel",
    "description": "Laravel adapter for the Gaze PII sanitization binary.",
    "license": "Apache-2.0",
    "keywords": ["laravel", "gdpr", "pii", "anonymization", "llm", "ai"],
    "homepage": "https://github.com/EmpireTwo/gaze-laravel",
    "support": {
        "issues": "https://github.com/EmpireTwo/gaze-laravel/issues",
        "source": "https://github.com/EmpireTwo/gaze-laravel",
        "docs": "https://github.com/EmpireTwo/gaze-laravel/blob/main/docs"
    },
    "authors": [
        {
            "name": "Naoray",
            "homepage": "https://github.com/Naoray"
        },
        {
            "name": "mg",
            "email": "m.gottschau.ext@ndr.de"
        },
        {
            "name": "The Gaze Contributors",
            "homepage": "https://github.com/EmpireTwo/gaze-laravel/graphs/contributors"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-phar": "*",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/encryption": "^11.0|^12.0",
        "illuminate/process": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "composer-plugin-api": "^2.0",
        "symfony/process": "^7.0 || ^8.0",
        "yosymfony/toml": "^1.0",
        "symfony/http-client": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpstan/phpstan": "^1.11",
        "laravel/pint": "^1.17",
        "composer/composer": "^2.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Naoray\\GazeLaravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Naoray\\GazeLaravel\\Tests\\": "tests/"
        },
        "files": [
            "tests/Helpers.php"
        ]
    },
    "extra": {
        "class": "Naoray\\GazeLaravel\\Install\\GazeInstallerPlugin",
        "laravel": {
            "providers": ["Naoray\\GazeLaravel\\GazeServiceProvider"],
            "aliases": {"Gaze": "Naoray\\GazeLaravel\\Facades\\Gaze"}
        }
    },
    "type": "composer-plugin",
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse",
        "format": "pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "naoray/gaze-laravel": true
        }
    }
}
